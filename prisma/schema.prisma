generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ball {
  id                    String   @id
  canonicalName         String
  brand                 String
  manufacturer          String
  coverstockName        String?
  coverstockType        String
  coreName              String?
  coreType              String
  factoryFinish         String?
  rg                    Float?
  differential          Float?
  mbDifferential        Float?
  availableWeightsJson  String?
  officialUrl           String?
  imageUrl              String?
  isCurrent             Boolean  @default(true)
  firstSeenAt           DateTime
  lastSeenAt            DateTime
  removedFromLineupAt   DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  listings              RetailerListing[]
  lineupEvents          LineupEvent[]

  @@index([canonicalName])
  @@index([brand])
  @@index([isCurrent])
}

model RetailerListing {
  id                String   @id
  ballId            String
  retailerName      String
  retailerType      String
  listingTitle      String
  listingUrl        String
  condition         String
  matchConfidence   Int
  matchStatus       String
  currentPrice      Float
  stockStatus       String
  lastCheckedAt     DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ball              Ball            @relation(fields: [ballId], references: [id])
  priceHistory      PriceSnapshot[]

  @@index([ballId])
  @@index([retailerName])
  @@index([stockStatus])
}

model PriceSnapshot {
  id                  String   @id
  retailerListingId   String
  price               Float
  stockStatus         String
  checkedAt           DateTime
  createdAt           DateTime @default(now())

  listing             RetailerListing @relation(fields: [retailerListingId], references: [id])

  @@index([retailerListingId])
  @@index([checkedAt])
}

model LineupEvent {
  id          String   @id
  ballId      String?
  eventType   String
  sourceName  String
  sourceUrl   String?
  detectedAt  DateTime
  notes       String?
  createdAt   DateTime @default(now())

  ball        Ball?    @relation(fields: [ballId], references: [id])

  @@index([ballId])
  @@index([eventType])
  @@index([detectedAt])
}

model ScrapeRun {
  id             String   @id
  sourceName     String
  sourceType     String
  status         String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  itemsFound     Int      @default(0)
  itemsCreated   Int      @default(0)
  itemsUpdated   Int      @default(0)
  itemsRemoved   Int      @default(0)
  errorMessage   String?
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sourceName])
  @@index([sourceType])
  @@index([status])
  @@index([startedAt])
}

model AlertLog {
  id                 String   @id
  dedupeKey          String
  destinationType    String
  destinationId      String?
  destinationKey     String
  alertType          String
  ballId             String?
  retailerListingId  String?
  message            String
  payloadJson        String?
  sentAt             DateTime
  createdAt          DateTime @default(now())

  @@unique([dedupeKey, destinationKey])
  @@index([alertType])
  @@index([ballId])
  @@index([retailerListingId])
  @@index([destinationType])
  @@index([sentAt])
}