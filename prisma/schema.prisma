generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ball {
  id                   String    @id
  canonicalName        String
  brand                String
  manufacturer         String
  coverstockName       String?
  coverstockType       String
  coreName             String?
  coreType             String
  factoryFinish        String?
  rg                   Float?
  differential         Float?
  mbDifferential       Float?
  availableWeightsJson String?
  officialUrl          String?
  imageUrl             String?
  isCurrent            Boolean   @default(true)
  firstSeenAt          DateTime
  lastSeenAt           DateTime
  removedFromLineupAt  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  listings     RetailerListing[]
  lineupEvents LineupEvent[]

  @@index([canonicalName])
  @@index([brand])
  @@index([isCurrent])
}

model RetailerListing {
  id              String   @id
  ballId          String
  retailerName    String
  retailerType    String
  listingTitle    String
  listingUrl      String
  condition       String
  matchConfidence Int
  matchStatus     String
  currentPrice    Float
  stockStatus     String
  lastCheckedAt   DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ball         Ball            @relation(fields: [ballId], references: [id])
  priceHistory PriceSnapshot[]

  @@index([ballId])
  @@index([retailerName])
  @@index([stockStatus])
}

model PriceSnapshot {
  id                String   @id
  retailerListingId String
  price             Float
  stockStatus       String
  checkedAt         DateTime
  createdAt         DateTime @default(now())

  listing RetailerListing @relation(fields: [retailerListingId], references: [id])

  @@index([retailerListingId])
  @@index([checkedAt])
}

model LineupEvent {
  id         String   @id
  ballId     String?
  eventType  String
  sourceName String
  sourceUrl  String?
  detectedAt DateTime
  notes      String?
  createdAt  DateTime @default(now())

  ball Ball? @relation(fields: [ballId], references: [id])

  @@index([ballId])
  @@index([eventType])
  @@index([detectedAt])
}

model ScrapeRun {
  id           String    @id
  sourceName   String
  sourceType   String
  status       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  itemsFound   Int       @default(0)
  itemsCreated Int       @default(0)
  itemsUpdated Int       @default(0)
  itemsRemoved Int       @default(0)
  errorMessage String?
  metadataJson String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sourceName])
  @@index([sourceType])
  @@index([status])
  @@index([startedAt])
}

model AlertLog {
  id                String   @id
  dedupeKey         String
  destinationType   String
  destinationId     String?
  destinationKey    String
  alertType         String
  ballId            String?
  retailerListingId String?
  message           String
  payloadJson       String?
  sentAt            DateTime
  createdAt         DateTime @default(now())

  @@unique([dedupeKey, destinationKey])
  @@index([alertType])
  @@index([ballId])
  @@index([retailerListingId])
  @@index([destinationType])
  @@index([sentAt])
}

model TrackedRetailerSource {
  id               String   @id
  name             String
  retailerName     String
  sourceKind       String
  url              String
  enabled          Boolean  @default(true)
  maxPages         Int?
  maxProducts      Int?
  scrapeDelayMs    Int?
  allowLikelyMatch Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([retailerName, url])
  @@index([retailerName])
  @@index([sourceKind])
  @@index([enabled])
}

model TrackedManufacturerSource {
  id               String   @id
  name             String
  manufacturerName String
  brandName        String?
  sourceKind       String
  parserKey        String
  url              String
  enabled          Boolean  @default(true)
  maxPages         Int?
  maxProducts      Int?
  scrapeDelayMs    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([manufacturerName, url])
  @@index([manufacturerName])
  @@index([brandName])
  @@index([sourceKind])
  @@index([parserKey])
  @@index([enabled])
}

model RetailerReviewItem {
  id                    String   @id
  retailerName          String
  retailerType          String?
  listingTitle          String
  listingUrl            String   @unique
  condition             String?
  scrapeStatus          String
  reviewStatus          String   @default("pending")
  reviewReason          String?
  currentPrice          Float?
  stockStatus           String?
  selectedBallId        String?
  selectedBallName      String?
  selectedBrand         String?
  selectedCatalogState  String?
  selectedConfidence    Int?
  selectedMatchStatus   String?
  topMatchesJson        String?
  firstSeenAt           DateTime @default(now())
  lastSeenAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([retailerName])
  @@index([scrapeStatus])
  @@index([reviewStatus])
  @@index([reviewReason])
  @@index([lastSeenAt])
}
